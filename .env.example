# The Blue Alliance API Key
# Get your key from https://www.thebluealliance.com/account
TBA_API_KEY=your_tba_api_key_here

# Event Key
TBA_EVENT_KEY=2024mibel

# Model selection for UI + scripts
# Preferred model (UI tries this first), falls back if missing.
MODEL_PATH=models/yolov8m_robots.pt
MODEL_FALLBACK_PATH=yolov8m.pt

# Detection confidence thresholds
DETECTION_CONF_LIVE=0.5
DETECTION_CONF_VIDEO=0.5

# Custom tracker defaults (used by the UI overlay + UI video processing)
TRACKING_ENABLED=true
TRACKER_MAX_ROBOTS=6
TRACKER_MAX_MISSES=60
TRACKER_MAX_LOST_AGE=150

# Ultralytics tracker config used by the UI (BoT-SORT by default)
ULTRALYTICS_TRACKER_YAML=botsort.yaml

# Optional: if set, both the capture client and web viewer must provide the token.
# This is a lightweight guard if you expose the server on a network.
STREAM_TOKEN=
